# ── App ──────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ideavault:password@localhost:5432/ideavault
SYNC_DATABASE_URL=postgresql://ideavault:password@localhost:5432/ideavault

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Storage (MinIO / S3) ──────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ideavault
MINIO_SECURE=false

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_TOKENS=10
RATE_LIMIT_REFILL_RATE=1
RATE_LIMIT_CAPACITY=20

# ── Cache ─────────────────────────────────────────────────────────
LRU_CACHE_CAPACITY=512
BLOOM_FILTER_CAPACITY=100000
BLOOM_FILTER_ERROR_RATE=0.01

# ── Generation ────────────────────────────────────────────────────
DEFAULT_IMAGE_MODEL=black-forest-labs/flux-schnell
DEFAULT_VIDEO_MODEL=wan-video/wan2.1-t2v-480p
MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT_SECONDS=300
